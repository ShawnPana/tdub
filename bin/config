#!/usr/bin/env bash
# config — ask terminum to open its settings window. Works inside tmux by
# wrapping the OSC in DCS passthrough. Outside terminum this is a silent
# no-op (the OSC is ignored).

if [ -n "${TMUX:-}" ]; then
  tmux set -g -q allow-passthrough on 2>/dev/null
  printf '\ePtmux;\e\e]1983;terminum-config\e\e\\\e\\'
else
  printf '\e]1983;terminum-config\e\\'
fi
