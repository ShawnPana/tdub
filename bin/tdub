#!/usr/bin/env bash
# tdub — dispatcher for tdub subcommands.
set -e
here="$(cd "$(dirname "$0")" && pwd)"
cmd="${1:-help}"
shift || true

case "$cmd" in
  browse)
    exec "$here/browse" "$@"
    ;;
  config)
    exec "$here/config" "$@"
    ;;
  help|-h|--help|'')
    cat <<'USAGE'
tdub — commands for the tdub terminal.

  tdub browse [url]   Turn the focused pane into a browser.
  tdub config         Open ~/.config/tdub/config.json in $EDITOR.

Shorthand: `browse` and `config` are aliases for the above.
USAGE
    ;;
  *)
    echo "tdub: unknown subcommand '$cmd'" >&2
    echo "try: tdub help" >&2
    exit 1
    ;;
esac
