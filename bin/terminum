#!/usr/bin/env bash
# terminum — dispatcher for terminum subcommands.
set -e
here="$(cd "$(dirname "$0")" && pwd)"
cmd="${1:-help}"
shift || true

case "$cmd" in
  browse)
    exec "$here/browse" "$@"
    ;;
  config)
    exec "$here/config" "$@"
    ;;
  help|-h|--help|'')
    cat <<'USAGE'
terminum — commands for the terminum terminal.

  terminum browse [url]   Turn the focused pane into a browser.
  terminum config         Open ~/.config/terminum/config.json in $EDITOR.

Shorthand: `browse` and `config` are aliases for the above.
USAGE
    ;;
  *)
    echo "terminum: unknown subcommand '$cmd'" >&2
    echo "try: terminum help" >&2
    exit 1
    ;;
esac
